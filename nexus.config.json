{
  "nexus_version": "9.2",
  "platform": "auto",
  "memory": {
    "enabled": true,
    "auto_capture_post_pipeline": true,
    "auto_reinject_on_boot": true,
    "max_blocks": 50,
    "max_tokens_per_block": 200,
    "progressive_disclosure_default": 1,
    "compress_threshold": 50,
    "path_claude_code": ".claude/memory/{proyecto}-memory.md",
    "path_claude_ai": "PROJECT-knowledge.md#memoria",
    "_note": "Legacy memory engine v7.2. Migrado a wiki_memory en v8.0. Se mantiene como fallback."
  },
  "wiki_memory": {
    "enabled": true,
    "path": "auto",
    "path_windows": "C:\\Users\\javi2\\.claude\\nexus-wiki",
    "path_unix": "~/.claude/nexus-wiki",
    "path_obsidian_alt": "~/ObsidianVaults/nexus-wiki",
    "_path_note": "Si path=auto, detecta plataforma. Si el usuario tiene Obsidian en otra ruta, usar path_obsidian_alt.",
    "hot_cache_on_boot": true,
    "hot_cache_max_tokens": 500,
    "auto_capture_post_pipeline": true,
    "auto_save_on_session_end": true,
    "defuddle_enabled": true,
    "defuddle_fallback": "web_fetch",
    "max_pages_per_ingest": 5,
    "query_max_pages": 5,
    "lint_every_n_ingests": 15,
    "domains_from_file": "wiki/verticals.md",
    "worker": "agents/wiki-memory-worker.md",
    "migrate_on_init": {
      "nexus_memory_json": true,
      "marketos_client_knowledge": true,
      "project_knowledge": true,
      "_note": "Al inicializar wiki, migrar conocimiento existente de v7.2, MarketOS y PROJECT-knowledge"
    },
    "_note": "Wiki Memory v8.0 — conocimiento acumulativo en vault. Backend principal de memoria."
  },
  "sequential_thinking": {
    "enabled": true,
    "auto_activate_for": [
      "goal_decomposition",
      "error_recovery_l4+",
      "learning_postmortem",
      "routing_ambiguous_5+"
    ],
    "user_triggers": ["complejo", "complex", "analiza a fondo", "piensa bien", "proyecto grande", "--deep"],
    "max_thoughts_per_call": 10,
    "max_st_calls_per_session": 3,
    "fallback_if_unavailable": "native_reasoning",
    "warn_on_token_estimate": true,
    "_note": "Sequential Thinking v9.1 — activación condicional. Solo cuando agrega valor real. ~$0.15-0.30/mes adicional."
  },
  "context_switching": {
    "enabled": true,
    "hot_snapshots_dir": "wiki/.hot-snapshots",
    "auto_switch_on_domain_change": true,
    "max_snapshots": 15,
    "_note": "Context Switching v9.1 — cambio rápido entre proyectos con hot cache por dominio."
  },
  "skill_audit": {
    "enabled": true,
    "auto_suggest_after_n_sessions": 50,
    "archive_dir": "warehouse/_archived",
    "irrelevant_stack_penalty": 0.3,
    "_note": "Skill Health Audit v9.1 — auditoría de duplicados, obsoletas, gaps."
  },
  "ruflo": {
    "enabled": true,
    "mcp_name": "ruflo",
    "auto_detect": true,
    "sync_every_n_sessions": 5,
    "sync_scope_default": "delta",
    "vector_search_fallback": "wiki_grep",
    "swarm_max_agents": 5,
    "delegation_log": "wiki/nexus-core/ruflo-delegation-log.md",
    "tools_used": [
      "memory_store",
      "memory_search",
      "health_check",
      "swarm_init",
      "swarm_status",
      "agent_spawn",
      "intelligence_query"
    ],
    "tools_excluded": [
      "federation_*",
      "security_*",
      "browser_*"
    ],
    "_note": "Ruflo Bridge v9.2 — motor de ejecución para vector search, swarm, SONA. Fallback graceful si no instalado."
  },
  "n8n": {
    "api_url": "https://TU-INSTANCIA.n8n.cloud",
    "api_key": "TU_N8N_API_KEY",
    "webhook_secret": "TU_WEBHOOK_SECRET"
  },
  "stitch": {
    "api_key": "TU_STITCH_API_KEY",
    "default_framework": "React",
    "default_styles": "Tailwind",
    "checkpoint_required": true
  },
  "meta": {
    "mcp_url": "https://mcp.facebook.com/ads",
    "enabled": "auto",
    "scope": "read_only",
    "_note": "MCP oficial de Meta (abril 2026). Se detecta automáticamente si está conectado como integración en Claude."
  },
  "watchdog": {
    "enabled": true,
    "check_interval_minutes": 30,
    "auto_deploy_on_workflow_deploy": true,
    "canal_default": {
      "tipo": "telegram",
      "destino": "TU_CHAT_ID"
    },
    "autofix": {
      "enabled": true,
      "max_retries": 3,
      "notify_before_fix": false
    },
    "alertas": {
      "error_consecutivos": 3,
      "latencia_ms": 5000,
      "tasa_error_pct": 20
    }
  },
  "projects": {
    "default": {
      "name": "proyecto-actual",
      "root": "./",
      "stack": "NestJS + Prisma + PostgreSQL + Redis + Vanilla JS",
      "knowledge_base": "PROJECT-knowledge.md",
      "protected_files": [
        "prisma/schema.prisma",
        ".env",
        "package.json"
      ]
    }
  },
  "codex": {
    "preferred_mechanism": "auto",
    "sandbox": "workspace-write",
    "skill_injection": true
  },
  "parallel": {
    "mode": "auto",
    "max_workers": 4,
    "p3_port": 9000
  },
  "security": {
    "audit_external_skills": true,
    "block_on_dangerous": true,
    "confirm_on_review": true
  },
  "learning": {
    "auto_distill_post_pipeline": true,
    "min_decisions_to_distill": 3
  },
  "catalog": {
    "location": "~/.claude/catalog/",
    "root": "~/.claude/catalog/catalog-root.json",
    "modules_dir": "~/.claude/catalog/",
    "total_modules": 16,
    "max_modules_per_pipeline": 5,
    "module_match_threshold": 0.2,
    "entry_match_threshold": 0.3
  },
  "auto_ingest": {
    "enabled": true,
    "scan_paths": [
      "~/.claude/skills/",
      "~/.claude/agents/",
      "~/.claude/plugins/",
      "./.claude/skills/",
      "./.claude/agents/"
    ],
    "on_new_file": "analyze_and_catalog",
    "on_delete_file": "remove_from_catalog",
    "on_modify_file": "re_analyze",
    "security_audit_third_party": true,
    "ingest_worker": "agents/catalog-ingest-worker.md"
  },
  "paths": {
    "nexus_home": "~/.claude/skills/nexus/",
    "warehouse": "~/.claude/warehouse/",
    "catalog": "~/.claude/catalog/",
    "memory": "~/.claude/nexus-memory.json",
    "log": "~/.claude/nexus-log.md",
    "backup": "~/.claude/skills-backup-{date}/"
  },
  "warehouse": {
    "enabled": true,
    "location": "~/.claude/warehouse/",
    "backup_before_init": true,
    "symlink_mode": true,
    "cleanup_on_boot": true,
    "cleanup_on_pipeline_end": true,
    "never_warehouse": [
      "nexus"
    ],
    "worker": "agents/warehouse-worker.md"
  }
}